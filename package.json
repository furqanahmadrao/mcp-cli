{
    "name": "mcpcli",
    "version": "0.1.0",
    "description": "Lightweight MCP CLI gateway client - agent-first, stateless tool execution",
    "main": "dist/index.js",
    "bin": {
        "mcp": "dist/cli/cli.js"
    },
    "type": "module",
    "scripts": {
        "dev": "tsx src/cli/cli.ts",
        "build": "tsc",
        "watch": "tsc --watch",
        "test": "vitest",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write src",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "cli",
        "gateway",
        "tools",
        "agents"
    ],
    "author": "Furqan",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "chalk": "^5.3.0",
        "commander": "^11.1.0",
        "zod": "^4.0.0",
        "yaml": "^2.3.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "eslint": "^8.55.0",
        "prettier": "^3.1.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}